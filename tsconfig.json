// now for module 

{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist",
    "rootDir": "src",
    "resolveJsonModule": true,
    "noImplicitAny": true,
    "types": ["node"]
  },

  "include": ["src/**/*"],

  "exclude": ["node_modules", "dist"]
}